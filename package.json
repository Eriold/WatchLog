{
  "name": "watchlog",
  "private": true,
  "version": "1.0.0-beta.1",
  "type": "module",
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "preinstall": "node ./scripts/enforce-dependency-policy.mjs",
    "dev": "vite",
    "build": "node ./scripts/build.mjs",
    "build:chrome": "node ./scripts/build.mjs chrome",
    "build:firefox": "node ./scripts/build.mjs firefox",
    "build:release": "node ./scripts/build-release-artifacts.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "deps:policy": "node ./scripts/enforce-dependency-policy.mjs"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.4.0",
    "@eslint/js": "9.39.4",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.1.39",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "archiver": "7.0.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.4.0",
    "jsdom": "29.0.1",
    "semantic-release": "25.0.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  }
}
